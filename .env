# AfroMed Medical Dashboard
VITE_APP_VERSION=v1.0.0
GENERATE_SOURCEMAP=false

## Public URL
PUBLIC_URL=http://localhost:3000
VITE_APP_BASE_NAME=

## API Configuration
# In development the Vite proxy rewrites /api/* → VITE_API_BACKEND_URL/api/*
# so the browser never makes a cross-origin request.
VITE_API_BASE_URL=/api
VITE_API_BACKEND_URL=http://localhost:8080

## Backend Server
PORT=8080
CORS_ORIGIN=http://localhost:3002

## Database
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URI=postgresql://afromed:afromed_password@afromed-db:5432/afromed_local_database
# Set to true when the DB host requires SSL (e.g. cloud providers)
DATABASE_SSL=false