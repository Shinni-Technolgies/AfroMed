# ---- Stage 1: Build ----
FROM node:20-alpine AS build

WORKDIR /app

# Install dependencies first (leverages Docker layer caching)
COPY package.json package-lock.json ./
RUN npm ci

# Copy source files needed for the build
COPY index.html favicon.svg vite.config.ts tsconfig.json tsconfig.node.json ./
COPY src/ src/

# Accept VITE_* variables as build args so they are embedded by Vite
# without hardcoding an .env file into the image.
ARG VITE_APP_VERSION=v1.0.0
ARG VITE_APP_NAME=AfroMed Dashboard
ARG VITE_APP_BASE_NAME=
ARG VITE_API_BASE_URL=/api

RUN npm run build

# ---- Stage 2: Serve with nginx ----
FROM nginx:stable-alpine

# Remove default nginx site
RUN rm /etc/nginx/conf.d/default.conf

# Copy custom nginx configuration
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Copy built assets from the build stage
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
