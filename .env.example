# AfroMed Medical Dashboard - Environment Configuration
# Copy this file to .env and update the values as needed

# ===========================================
# APPLICATION SETTINGS
# ===========================================
VITE_APP_VERSION=v1.0.0
VITE_APP_NAME=AfroMed Dashboard

# Generate source maps (set to true for debugging)
GENERATE_SOURCEMAP=false

# ===========================================
# SERVER / URLs
# ===========================================
# Public URL for the application
PUBLIC_URL=http://localhost:3000

# Base name for routing (leave empty for root)
VITE_APP_BASE_NAME=

# ===========================================
# API CONFIGURATION
# ===========================================
# Relative path kept as-is — Vite dev proxy forwards /api/* to VITE_API_BACKEND_URL in development.
# In production point this at your deployed API: https://api.yourdomain.com/api
VITE_API_BASE_URL=/api

# Backend origin that the Vite proxy (and CORS header) targets
VITE_API_BACKEND_URL=http://localhost:8080

# API timeout in milliseconds
VITE_API_TIMEOUT=30000

# ===========================================
# BACKEND SERVER
# ===========================================
PORT=8080

# Allowed origin for CORS (your frontend URL)
CORS_ORIGIN=http://localhost:3000

# ===========================================
# DATABASE
# ===========================================
# PostgreSQL connection URI — replace placeholders with your actual credentials
# Format: postgresql://DB_USER:DB_PASSWORD@DB_HOST:DB_PORT/DB_NAME
DATABASE_URI=postgresql://DB_USER:DB_PASSWORD@DB_HOST:DB_PORT/DB_NAME

# Set to true when your database host requires SSL (e.g. Supabase, Neon, Render)
DATABASE_SSL=false

# ===========================================
# AUTHENTICATION
# ===========================================
# JWT secret key (for development only - use secure key in production)
VITE_JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Token expiration time
VITE_TOKEN_EXPIRY=24h

# ===========================================
# THIRD-PARTY SERVICES (Optional)
# ===========================================
# Google Maps API Key (for clinic location features)
VITE_GOOGLE_MAPS_API_KEY=

# Firebase configuration (for notifications)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ===========================================
# FEATURE FLAGS
# ===========================================
# Enable/disable features
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_NOTIFICATIONS=true
VITE_ENABLE_TELEMEDICINE=false

# ===========================================
# MEDICAL SPECIFIC SETTINGS
# ===========================================
# Default appointment duration in minutes
VITE_DEFAULT_APPOINTMENT_DURATION=30

# Maximum patients per day
VITE_MAX_PATIENTS_PER_DAY=50

# Clinic opening hours (24h format)
VITE_CLINIC_OPEN_TIME=08:00
VITE_CLINIC_CLOSE_TIME=18:00
